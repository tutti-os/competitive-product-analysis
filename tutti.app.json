{
  "schemaVersion": "tutti.app.manifest.v1",
  "appId": "product-competition",
  "version": "0.2.0",
  "name": "Competitive Analysis",
  "description": "Compare competitor positioning, features, and UX to support product decisions.",
  "icon": {
    "type": "asset",
    "src": "icon.svg"
  },
  "runtime": {
    "bootstrap": "bootstrap.sh",
    "healthcheckPath": "/api/health"
  },
  "cli": {
    "manifest": "tutti.cli.json"
  },
  "references": {
    "listEndpoint": "/tutti/references/list",
    "searchEndpoint": "/tutti/references/search"
  },
  "window": {
    "minimizeBehavior": "keep-mounted",
    "minWidth": 1120,
    "minHeight": 720
  },
  "localizationInfo": {
    "defaultLocale": "en",
    "additionalLocales": [
      {
        "locale": "zh-CN",
        "file": "locales/zh-CN/manifest.json"
      }
    ]
  },
  "author": {
    "name": "Tutti"
  },
  "tags": [
    "local-first",
    "agent",
    "research",
    "competitive-intelligence"
  ]
}
